<Window x:Class="StarResonanceDpsAnalysis.WPF.Views.PersonalDpsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StarResonanceDpsAnalysis.WPF.Views"
        xmlns:vms="clr-namespace:StarResonanceDpsAnalysis.WPF.ViewModels"
        xmlns:ctrl="clr-namespace:StarResonanceDpsAnalysis.WPF.Controls"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:loc="clr-namespace:StarResonanceDpsAnalysis.WPF.Properties"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:StarResonanceDpsAnalysis.WPF.Behaviors"
        mc:Ignorable="d"
        Title="{lex:Loc Key={x:Static loc:ResourcesKeys.Window_PersonalDps_Title}}"
        SizeToContent="Width"
         Height="76"
        lex:LocalizeDictionary.DesignCulture="en-US"
        Style="{StaticResource TransparentWindow}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowState="Normal"
        d:DataContext="{d:DesignInstance Type=vms:PersonalDpsDesignTimeViewModel,
                                     IsDesignTimeCreatable=True}">

    <Window.Resources>

        <Style x:Key="SAOTTBase" TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlockBaseStyle}">
            <Setter Property="FontFamily" Value="pack://application:,,,/Assets/Fonts/#SAO Welcome TT" />
        </Style>

        <Style x:Key="CustomShadowWindowBorder" TargetType="Border" BasedOn="{StaticResource ShadowWindowBorder}">
            <Setter Property="CornerRadius" Value="33" />
            <EventSetter Event="MouseDown" Handler="ViewBorder_MouseDown"/>
        </Style>

        <Style x:Key="DragMoveBar" TargetType="Border">
            <Setter Property="Width" Value="48" />
            <Setter Property="Height" Value="4" />
            <Setter Property="Background" Value="#D6D7DB" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Margin" Value="0,7,0,0" />
        </Style>

        <Style x:Key="TimerBox" TargetType="Border">
            <Setter Property="Width" Value="80" />
            <Setter Property="Background" Value="#091B28" />
            <Setter Property="Margin" Value="12,12,0,12" />
            <Setter Property="CornerRadius" Value="21" />
        </Style>

        <Style x:Key="TimerText" TargetType="TextBlock" BasedOn="{StaticResource SAOTTBase}">
            <Setter Property="Foreground" Value="#FFF" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TotalDamageText" TargetType="TextBlock" BasedOn="{StaticResource SAOTTBase}">
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="Foreground" Value="{Binding ThemeColor, Converter={StaticResource ColorStringToBrushConverter}}" />
        </Style>

        <Style x:Key="DpsText" TargetType="TextBlock" BasedOn="{StaticResource SAOTTBase}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Foreground" Value="#666" />
        </Style>

        <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="FontFamily" Value="pack://application:,,,/Assets/Fonts/#IconFont" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Foreground" Value="#FF000000" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="2,0" />
        </Style>

        <Style x:Key="PercentProgressBar" TargetType="ctrl:CustomProgressBar" BasedOn="{StaticResource {x:Type ctrl:CustomProgressBar}}">
            <Setter Property="VerticalAlignment" Value="Bottom" />
            <Setter Property="Height" Value="4" />
            <Setter Property="CornerRadius" Value="2" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Margin" Value="28,0,28,4" />
            <Setter Property="Background" Value="#F3F3F3" />
            <Setter Property="Foreground" Value="{Binding ThemeColor, Converter={StaticResource ColorStringToBrushConverter}}" />
        </Style>

    </Window.Resources>
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="Loaded">
            <b:InvokeCommandAction Command="{Binding LoadedCommand}" />
        </b:EventTrigger>
        <b:EventTrigger EventName="Unloaded">
            <b:InvokeCommandAction Command="{Binding UnLoadedCommand}" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <Border Background="#FBFBFB" Style="{StaticResource CustomShadowWindowBorder}">
        <Grid>

            <Border Style="{StaticResource DragMoveBar}"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource TimerBox}" Grid.Column="0"
                        >
                    <TextBlock
                        Style="{StaticResource TimerText}"
                        Text="{Binding RemainingTimeDisplay}" />
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="12">
                    <StackPanel 
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        MinWidth="140">
                        <TextBlock Style="{StaticResource TotalDamageText}">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource HumanReadableNumberConverter}">
                                    <Binding Path="TotalDamage" />
                                    <Binding Path="AppConfig.DamageDisplayType" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>

                        <TextBlock Style="{StaticResource DpsText}" VerticalAlignment="Bottom">
                            <TextBlock.Text>
                                <MultiBinding Converter="{StaticResource HumanReadableNumberConverter}" StringFormat="{}({0})">
                                    <Binding Path="Dps" />
                                    <Binding Path="AppConfig.DamageDisplayType" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>

                    <!--  Mouse-through indicator (visible when click-through is enabled)  -->
                    <TextBlock
                            FontSize="22"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="pack://application:,,,/Assets/Fonts/#IconFont"
                            Text="&#xe83a;"
                            TextAlignment="Center"
                            ToolTip="{lex:Loc Key={x:Static loc:ResourcesKeys.DpsStatistics_Indicator_ClickThrough_Tooltip}}"
                            Visibility="{Binding DataContext.AppConfig.MouseThroughEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibilityConverter}}" />
                    <Button
                            Style="{StaticResource IconButton}"
                            Content="&#xec4c;"
                            Command="{Binding OpenSkillLogCommand}"
                           />
                    <Button
                            Style="{StaticResource IconButton}"
                            Content="&#xe612;"
                            Command="{Binding ShowStatisticsAndHidePersonalCommand}" />

                    <Button
                        Style="{StaticResource IconButton}"
                        Content="&#xeb95;"
                        Command="{Binding OpenSkillBreakdownViewCommand}" />
                    <!--  Topmost toggle button (pin / pin-fill)  -->
                    <Button
                            x:Name="TopmostButton"
                            Command="{Binding ToggleTopmostCommand}"
                            FontFamily="pack://application:,,,/Assets/Fonts/#iconfont"
                            ToolTip="{lex:Loc Key={x:Static loc:ResourcesKeys.DpsStatistics_Indicator_WindowTopMost_Tooltip}}">
                        <Button.Style>
                            <Style BasedOn="{StaticResource IconButton}" TargetType="Button">
                                <Setter Property="Content" Value="&#xe864;" />
                                <Style.Triggers>
                                    <DataTrigger
                                            Binding="{Binding Topmost, RelativeSource={RelativeSource AncestorType=Window}}"
                                            Value="True">
                                        <Setter Property="Content" Value="&#xe863;" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button
                        Style="{StaticResource IconButton}"
                        Content="&#xe6ad;">
                        <b:Interaction.Behaviors>
                            <behaviors:OpenContextMenuBehavior />
                        </b:Interaction.Behaviors>
                        <Button.ContextMenu>
                            <ContextMenu Style="{StaticResource ModernContextMenu}">
                                <ContextMenu.Resources>
                                    <Style BasedOn="{StaticResource ModernMenuItem}" TargetType="MenuItem" />
                                </ContextMenu.Resources>

                                <!-- 木桩选择菜单 -->
                                <MenuItem Header="{lex:Loc Key={x:Static loc:ResourcesKeys.Menu_Select_Training_Dummy}}">
                                    <MenuItem
                                        Header="{lex:Loc Key={x:Static loc:ResourcesKeys.Menu_Training_Dummy_Elite_Enemy}}"
                                        IsCheckable="True"
                                        IsChecked="{Binding SelectedDummyTarget, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Center}"
                                        StaysOpenOnClick="True" />
                                    <MenuItem
                                        Header="{lex:Loc Key={x:Static loc:ResourcesKeys.Menu_Training_Dummy_Elite_Tank}}"
                                        IsCheckable="True"
                                        IsChecked="{Binding SelectedDummyTarget, Mode=TwoWay, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=TDummy}"
                                        StaysOpenOnClick="True" />
                                </MenuItem>

                                <MenuItem
                                    Command="{Binding ClearCommand}"
                                    Header="{lex:Loc Key={x:Static loc:ResourcesKeys.Settings_PlayerInfo_Clear}}" />
                                <Separator />
                                <MenuItem
                                    Command="{Binding ShowStatisticsAndHidePersonalCommand}"
                                    Header="{lex:Loc Key={x:Static loc:ResourcesKeys.SkillLog_Button_Close}}" />
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </StackPanel>
            </Grid>

            <ctrl:CustomProgressBar
                Style="{StaticResource PercentProgressBar}"
                Maximum="1"
                Value="{Binding RemainingPercent, Mode=OneWay}" Margin="28,60,28,0" VerticalAlignment="Top" />

        </Grid>
    </Border>

</Window>
