<Window x:Class="StarResonanceDpsAnalysis.WPF.Views.BuffMonitorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:behaviors="clr-namespace:StarResonanceDpsAnalysis.WPF.Behaviors"
        xmlns:ctrl="clr-namespace:StarResonanceDpsAnalysis.WPF.Controls"
        xmlns:local="clr-namespace:StarResonanceDpsAnalysis.WPF.Views"
        xmlns:viewModels="clr-namespace:StarResonanceDpsAnalysis.WPF.ViewModels"
        xmlns:lex="http://wpflocalizeextension.codeplex.com"
        xmlns:loc="clr-namespace:StarResonanceDpsAnalysis.WPF.Properties"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=viewModels:BuffMonitorViewModel, IsDesignTimeCreatable=True}"
        Title="Buff Monitor" 
        Width="600" 
        Height="500"
        MinWidth="400"
        MinHeight="300"
        behaviors:WindowSnapBehavior.PreventSnapMaximize="True"
        lex:ResxLocalizationProvider.DefaultAssembly="StarResonanceDpsAnalysis.WPF"
        lex:ResxLocalizationProvider.DefaultDictionary="Resources"
        lex:LocalizeDictionary.DesignCulture="en-US"
        ResizeMode="CanResize"
        Topmost="{Binding AppConfig.TopmostEnabled, Mode=OneWay}" >

    <!--<WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>-->

    <Window.Resources>
        <!-- Title Text Style (matches DpsStatisticsView) -->
        <Style x:Key="StatisticTypeText" TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlockBaseStyle}">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <!-- Buff Item Style -->
        <Style x:Key="BuffItemBorder" TargetType="Border">
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="BorderBrush" Value="#44FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <Style x:Key="BuffNameText" TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlockBaseStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="BuffDetailText" TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlockBaseStyle}">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="BuffTimeText" TargetType="TextBlock" BasedOn="{StaticResource NormalTextBlockBaseStyle}">
            <Setter Property="Foreground" Value="#4CAF50"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="TopBarButton" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="21"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/Assets/Fonts/#iconfont"/>
        </Style>
    </Window.Resources>

    <!-- Main Border with Shadow (matches DpsStatisticsView) -->
    <Border Style="{StaticResource ShadowWindowBorder}">
        <Grid CacheMode="BitmapCache">
            <Grid.RowDefinitions>
                <RowDefinition Height="25"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar with Theme Color (matches DpsStatisticsView) -->
            <Border Grid.Row="0"
                    Height="25"
                    VerticalAlignment="Top"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Border.CornerRadius>
                    <CornerRadius
                        BottomLeft="0"
                        BottomRight="0"
                        TopLeft="{StaticResource MainCornerRadiusDouble}"
                        TopRight="{StaticResource MainCornerRadiusDouble}" />
                </Border.CornerRadius>
                <Border.Background>
                    <SolidColorBrush>
                        <SolidColorBrush.Color>
                            <MultiBinding Converter="{StaticResource ThemeColorWithOpacityConverter}">
                                <Binding Path="AppConfig.ThemeColor" />
                                <Binding Path="AppConfig.Opacity" />
                            </MultiBinding>
                        </SolidColorBrush.Color>
                    </SolidColorBrush>
                </Border.Background>

                <Grid Margin="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Title Text -->
                    <TextBlock Grid.Column="0"
                               Text="Buff Monitor"
                               Style="{StaticResource StatisticTypeText}"
                               VerticalAlignment="Center"
                               Margin="5,0,0,0"/>

                    <!-- Control Buttons -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <!-- Refresh Button -->
                        <Button Content="&#xE644;"
                                Command="{Binding RefreshCommand}"
                                Style="{StaticResource TopBarButton}"
                                ToolTip="Refresh"/>

                        <!-- Clear Button -->
                        <Button Content="&#xe668;"
                                Command="{Binding ClearBuffsCommand}"
                                Style="{StaticResource TopBarButton}"
                                ToolTip="Clear All"/>

                        <!-- Minimize Button -->
                        <Button Content="—"
                                Click="ButtonMinimizeClick"
                                Style="{StaticResource TopBarButton}"
                                FontSize="12"
                                ToolTip="Minimize"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Player Info Bar (below top bar) -->
            <Border Grid.Row="1"
                    Background="#22000000"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource BuffDetailText}">
                        <Run Text="Player:"/>
                        <Run Text="{Binding SelectedPlayerName, Mode=OneWay}" 
                             Foreground="White" 
                             FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Style="{StaticResource BuffDetailText}" Margin="15,0,0,0">
                        <Run Text="Active Buffs:"/>
                        <Run Text="{Binding ActiveBuffCount, Mode=OneWay}" 
                             Foreground="#4CAF50" 
                             FontWeight="Bold"/>
                    </TextBlock>
                    <CheckBox Content="Monitor All" 
                              IsChecked="{Binding MonitorAllBuffs}"
                              Foreground="#B0B0B0"
                              Margin="15,0,0,0"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Main Content Area with Dark Background -->
            <Grid Grid.Row="2">
                <!-- Dark Center Background (matches DpsStatisticsView CenterBackgroundColor) -->
                <Rectangle>
                    <Rectangle.Fill>
                        <SolidColorBrush 
                            Color="{Binding AppConfig.CenterBackgroundColor}"
                            Opacity="{Binding AppConfig.CenterBackgroundOpacity, Converter={StaticResource PercentToOpacityConverter}}" />
                    </Rectangle.Fill>
                </Rectangle>

                <!-- Buff List -->
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Margin="8">
                    <StackPanel>
                        <!-- Filter Section -->
                        <Border Background="#22FFFFFF"
                                BorderBrush="#44FFFFFF"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="6,4"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Filter:"
                                           Style="{StaticResource BuffDetailText}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         Foreground="White"
                                         BorderThickness="0"
                                         VerticalContentAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Buff Items List -->
                        <ItemsControl ItemsSource="{Binding FilteredBuffs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource BuffItemBorder}">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Buff Name -->
                                            <TextBlock Grid.Row="0" 
                                                       Grid.Column="0"
                                                       Style="{StaticResource BuffNameText}">
                                                <Run Text="{Binding DisplayName, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- Remaining Time -->
                                            <TextBlock Grid.Row="0"
                                                       Grid.Column="1"
                                                       Text="{Binding RemainingTimeFormatted, Mode=OneWay}"
                                                       Style="{StaticResource BuffTimeText}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"/>

                                            <!-- Buff Details (ID, Layer) -->
                                            <TextBlock Grid.Row="1"
                                                       Grid.Column="0"
                                                       Grid.ColumnSpan="2"
                                                       Style="{StaticResource BuffDetailText}"
                                                       Margin="0,2,0,0">
                                                <Run Text="ID:"/>
                                                <Run Text="{Binding BaseId, Mode=OneWay}"/>
                                                <Run Text=" | Layer:"/>
                                                <Run Text="{Binding Layer, Mode=OneWay}" Foreground="#4CAF50"/>
                                                <Run Text=" | Duration:"/>
                                                <Run Text="{Binding DurationMs, Mode=OneWay, StringFormat={}{0:N0}}"/>
                                                <Run Text="ms"/>
                                            </TextBlock>

                                            <!-- Progress Bar -->
                                            <ProgressBar Grid.Row="2"
                                                         Grid.ColumnSpan="2"
                                                         Height="4"
                                                         Margin="0,4,0,0"
                                                         Value="{Binding ProgressPercent, Mode=OneWay}"
                                                         Maximum="100"
                                                         BorderThickness="0"
                                                         Foreground="{Binding DataContext.AppConfig.ThemeColor, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource ColorStringToBrushConverter}}"
                                                         Background="#33FFFFFF"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
