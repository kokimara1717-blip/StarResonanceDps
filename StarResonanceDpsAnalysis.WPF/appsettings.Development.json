{
    "Config": {
        "DebugEnabled": true,
        "EnableAutoUpdate": true,
        "AutoUpdateCheckOnStartup": true,
        "UpdateSource": "GitHub",
        "GithubRepository": "anying1073/StarResonanceDps",
        "GithubIncludePrerelease": true,
        "GithubAssetNameContains": "WPF",
        "SelfHostedManifestUrl": "http://localhost:5107/api/update/latest",
        "UpdateRequestTimeoutSeconds": 10
    },
    "Logging": {
        "LogLevel": {
            "Default": "Trace",
            "Microsoft": "Debug",
            "Microsoft.Hosting.Lifetime": "Debug",
            "System": "Debug"
        }
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Verbose",
            "Override": {
                "Microsoft": "Debug",
                "System": "Debug"
            }
        }
    }
}