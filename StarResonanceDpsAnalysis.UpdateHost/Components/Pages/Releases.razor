@page "/releases"
@inject IGitHubReleaseCache GitHubReleaseCache

<PageTitle>Releases</PageTitle>

<h1>Release List</h1>

<p>Source: <code>/summary.json</code></p>

@if (_summary.Count == 0)
{
    <p>No releases available.</p>
}
else
{
    <table>
        <thead>
        <tr>
            <th>Version</th>
            <th>Type</th>
            <th>Published</th>
            <th>Download</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var release in _summary)
        {
            <tr>
                <td>@release.Version</td>
                <td>@(release.IsPrerelease ? "Prerelease" : "Stable")</td>
                <td>@(release.PublishedAt?.ToString("u") ?? "-")</td>
                <td><a href="@release.DownloadUrl">@release.DownloadUrl</a></td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<ReleaseSummaryItemDto> _summary = [];

    protected override void OnInitialized()
    {
        _summary = GitHubReleaseCache.GetSummary();
    }
}
